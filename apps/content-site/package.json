{
  "name": "topoodoc-content-site",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "content:sync": "node ../../scripts/sync-content-repo.mjs --site apps/content-site",
    "content:watch": "node ../../scripts/watch-content-repo.mjs --site apps/content-site",
    "dev": "node ../../scripts/dev-content-site.mjs --site apps/content-site",
    "build": "pnpm content:sync && pnpm exec next build --webpack",
    "deploy": "pnpm build && wrangler deploy",
    "start": "pnpm exec next start",
    "typecheck": "fumadocs-mdx && pnpm exec next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@topoo/fumadocs-system": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "fumadocs-core": "16.7.7",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.7",
    "next": "16.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "postcss": "^8.5.6",
    "rehype-pretty-code": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.63.0"
  }
}
